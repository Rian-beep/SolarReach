# ─── COPY THIS TO .env.local AND FILL IN VALUES ─────────────────
# .env.local is gitignored — never committed. Stays on your laptop.

# ─── MongoDB ─────────────────────────────────────────────────
# For local Docker stack (default — works out of the box):
MONGO_URI=mongodb://solarreach:solarreach@mongo:27017/solarreach?authSource=admin
# For Atlas Sandbox (REQUIRED for finalist eligibility — paste from CV email):
# MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=solarreach

# ─── Anthropic ──────────────────────────────────────────────
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_CONTENT=claude-sonnet-4-6
ANTHROPIC_MODEL_DECISION=claude-opus-4-7
ANTHROPIC_MODEL_VOICE=claude-haiku-4-5-20251001

# ─── Google Cloud (single key for ALL Google APIs) ──────────
# 1. Create a project at https://console.cloud.google.com
# 2. Enable APIs: Map Tiles, Maps JavaScript, Solar, Geocoding, Weather, Places (optional)
# 3. Create credentials → API Key
# 4. Application restrictions: NONE (HTTP referrer breaks server calls — cardinal rule)
GOOGLE_MAPS_API_KEY=AIza...
VITE_GOOGLE_MAPS_API_KEY=AIza...   # same key, exposed to browser

# ─── ElevenLabs ConvAI ──────────────────────────────────────
# https://elevenlabs.io/app — need both:
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# ─── UK Government APIs ─────────────────────────────────────
# Free, unlimited: https://developer.company-information.service.gov.uk/manage-applications
COMPANIES_HOUSE_API_KEY=

# ─── Optional ───────────────────────────────────────────────
VOYAGE_API_KEY=         # MongoDB embeddings partner (free 50M tokens/mo) — https://www.voyageai.com
HUNTER_API_KEY=         # mocked unless you flip live
RESEND_API_KEY=         # transactional email
MET_OFFICE_API_KEY=
FIREWORKS_API_KEY=

# ─── Compliance ─────────────────────────────────────────────
SOLARREACH_LIVE_OUTBOUND=false   # NEVER flip without review
ROI_GATE_THRESHOLD=70
SESSION_BUDGET_GBP=1.00

# ─── Frontend ───────────────────────────────────────────────
VITE_API_BASE=http://localhost:8000
