# SolarReach Codex Brain — production image (Celery worker).
# Includes LibreOffice headless for PPTX → PDF conversion.
# Build context: repo root (sibling packages: shared/py).

# ─── Stage 1: builder ────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    UV_LINK_MODE=copy \
    UV_SYSTEM_PYTHON=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.5.4 /uv /usr/local/bin/uv

WORKDIR /build

COPY packages/shared/py /build/packages/shared/py
COPY packages/codex/pyproject.toml /build/packages/codex/pyproject.toml
COPY packages/codex/uv.lock        /build/packages/codex/uv.lock
COPY packages/codex/README.md      /build/packages/codex/README.md
COPY packages/codex/codex_brain    /build/packages/codex/codex_brain

WORKDIR /build/packages/codex
RUN uv pip install --system --no-cache "."

# ─── Stage 2: runtime ────────────────────────────────────────────────────────
FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    REDIS_URL=redis://redis:6379/0 \
    MONGO_URI=mongodb://mongo:27017/?authSource=admin \
    MONGO_DB=solarreach

# LibreOffice + Inter font (deck branding) — same set as dev image.
RUN apt-get update && apt-get install -y --no-install-recommends \
        tini ca-certificates \
        libreoffice libreoffice-impress \
        fonts-inter fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system app && useradd --system --gid app --no-create-home --shell /usr/sbin/nologin app

COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

COPY --chown=app:app packages/codex/codex_brain /app/codex_brain

RUN mkdir -p /tmp/decks && chown -R app:app /tmp/decks

WORKDIR /app
USER app

# concurrency=2 keeps Anthropic rate-limit headroom; tune via env if needed.
ENV CELERY_CONCURRENCY=2

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["sh", "-c", "exec celery -A codex_brain.celery_app:celery_app worker --loglevel=info --concurrency=${CELERY_CONCURRENCY}"]
