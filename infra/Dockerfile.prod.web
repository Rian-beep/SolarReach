# SolarReach Web — production image.
# Stage 1: build the Vite bundle. Stage 2: serve with nginx.
# Build context: packages/web (so this Dockerfile sees the package directly).
#
# Public env vars are baked at build time. To change them, rebuild.
# Caller can pass:
#   --build-arg VITE_API_BASE=https://api.solarreach.example
#   --build-arg VITE_GOOGLE_MAPS_API_KEY=AIza...
# At runtime, $UPSTREAM_API controls the nginx reverse-proxy target
# (defaults to 'api:8000' for docker-compose deployments).

# ─── Stage 1: build ──────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

# Manifests first for layer caching
COPY package.json pnpm-lock.yaml* ./

# Install only what this package needs (no workspace recursion).
RUN pnpm install --no-frozen-lockfile --ignore-scripts

# Source
COPY tsconfig.json vite.config.ts postcss.config.js tailwind.config.js index.html ./
COPY public ./public
COPY src ./src

# Build-time public vars (Vite inlines anything VITE_*).
ARG VITE_API_BASE="/api"
ARG VITE_GOOGLE_MAPS_API_KEY=""
ENV VITE_API_BASE=${VITE_API_BASE} \
    VITE_GOOGLE_MAPS_API_KEY=${VITE_GOOGLE_MAPS_API_KEY}

RUN pnpm build

# ─── Stage 2: nginx runtime ──────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# envsubst lives in gettext on alpine — used to interpolate $UPSTREAM_API
# at container start (without disturbing nginx's own $host / $uri vars).
RUN apk add --no-cache gettext \
    && rm -f /etc/nginx/conf.d/default.conf

# Built static bundle
COPY --from=builder /app/dist /usr/share/nginx/html

# nginx config template — only ${UPSTREAM_API} gets substituted at boot.
RUN cat > /etc/nginx/conf.d/solarreach.conf.template <<'NGINX'
server {
    listen 80 default_server;
    server_name _;

    gzip on;
    gzip_comp_level 6;
    gzip_min_length 256;
    gzip_proxied any;
    gzip_vary on;
    gzip_types
        application/javascript
        application/json
        application/xml
        font/woff2
        image/svg+xml
        text/css
        text/plain
        text/xml;

    # Long cache for hashed Vite assets
    location /assets/ {
        root /usr/share/nginx/html;
        access_log off;
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # Reverse-proxy API + SSE. UPSTREAM_API is interpolated at boot.
    location ~ ^/(api|scan|lead|voice|admin|financial|health|static)(/.*)?$ {
        proxy_pass            http://${UPSTREAM_API}$request_uri;
        proxy_http_version    1.1;
        proxy_set_header      Host $host;
        proxy_set_header      X-Real-IP $remote_addr;
        proxy_set_header      X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto $scheme;

        # SSE: disable buffering, long timeouts
        proxy_buffering       off;
        proxy_cache           off;
        proxy_read_timeout    1h;
        proxy_send_timeout    1h;
        chunked_transfer_encoding on;
    }

    # SPA fallback
    location / {
        root /usr/share/nginx/html;
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache";
    }
}
NGINX

ENV UPSTREAM_API=api:8000

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
    CMD wget -qO- http://127.0.0.1/ > /dev/null || exit 1

CMD ["sh", "-c", "envsubst '${UPSTREAM_API}' < /etc/nginx/conf.d/solarreach.conf.template > /etc/nginx/conf.d/solarreach.conf && exec nginx -g 'daemon off;'"]
