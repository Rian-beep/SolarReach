{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "solarreach://schemas/directors.schema.json",
  "title": "Director",
  "type": "object",
  "required": ["_id", "company_id", "name"],
  "additionalProperties": true,
  "properties": {
    "_id": { "type": "string", "pattern": "^director_" },
    "company_id": { "type": "string" },
    "name": { "type": "string" },
    "name_display": { "type": ["string", "null"] },
    "role": { "type": ["string", "null"] },
    "appointed_on": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"] },
    "linkedin_url": { "type": ["string", "null"] },
    "ch_officer_id": { "type": ["string", "null"] }
  }
}
