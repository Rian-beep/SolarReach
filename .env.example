# ─── MongoDB ──────────────────────────────────────────────────
# Atlas connection string (FINALIST REQUIREMENT)
# Format: mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://solarreach:solarreach@mongo:27017/solarreach?authSource=admin
MONGO_DB=solarreach

# ─── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_CONTENT=claude-sonnet-4-6
ANTHROPIC_MODEL_DECISION=claude-opus-4-7
ANTHROPIC_MODEL_VOICE=claude-haiku-4-5-20251001

# ─── Google Cloud (single key for ALL Google APIs) ────────────
# Application restrictions MUST be "None" or IP-allowlist (NOT HTTP referrer)
# APIs to enable: Map Tiles, Maps JavaScript, Solar, Geocoding, Weather, Places
GOOGLE_MAPS_API_KEY=AIza...

# ─── ElevenLabs ConvAI ────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# ─── UK Government APIs (free) ────────────────────────────────
COMPANIES_HOUSE_API_KEY=
# HTTP Basic auth: key as username, blank password

# ─── Optional ─────────────────────────────────────────────────
VOYAGE_API_KEY=                  # MongoDB partner, free 50M tokens/mo
HUNTER_API_KEY=                  # mocked unless explicitly enabled
RESEND_API_KEY=                  # transactional email
MET_OFFICE_API_KEY=              # UK weather (free signup)
FIREWORKS_API_KEY=               # alternative LLM/STT/TTS

# ─── Compliance ───────────────────────────────────────────────
# DO NOT FLIP TO TRUE WITHOUT EXPLICIT REVIEW
SOLARREACH_LIVE_OUTBOUND=false
ROI_GATE_THRESHOLD=70
SESSION_BUDGET_GBP=1.00

# ─── Frontend (Vite) ──────────────────────────────────────────
VITE_API_BASE=http://localhost:8000
VITE_GOOGLE_MAPS_API_KEY=
# NOTE: separate key recommended for browser; can reuse GOOGLE_MAPS_API_KEY for hackathon
